# Marg configuration. Drop this at ./marg.toml or point to it with
# `marg start --config /path/to/marg.toml`. If the file is missing, defaults
# below are used.

[server]
# Address the HTTP server binds to.
bind = "0.0.0.0:8080"
# Maximum request body size accepted on chat endpoints (bytes). Default 1 MiB.
max_body_bytes = 1048576

[storage]
# Choose "sqlite" (default, single file) or "postgres" (production).
backend = "sqlite"
# Path for the sqlite backend. Ignored for postgres.
path = "./marg.db"
# DSN for the postgres backend. Required when backend = "postgres".
# Secret reference shapes: plain:<value>, env:<NAME>, file:<path>.
# Examples:
#   dsn = "postgres://marg:secret@localhost:5432/marg"
#   dsn = "env:MARG_PG_DSN"
#   dsn = "file:/etc/marg/pg.dsn"

# Optional hot store (used for budget reservation and per-key rpm rate limits).
# Required for clustered deployments where multiple Marg instances share state.
# When omitted, a per-process in-memory hot store is used.
# [storage.hot]
# backend = "redis"
# url = "redis://localhost:6379"
# # Optional key namespace for sharing one Redis across multiple Marg fleets.
# key_prefix = "marg"

# Asynchronous write batcher (P08). Spend deltas and request-log rows are
# enqueued onto a bounded channel and flushed in batches by a background
# task, so the request path is not blocked on durable-storage writes. On a
# full queue Marg fails closed: the request returns 503 with x-marg-reason:
# storage_overloaded. Defaults are sized for ~5,000 req/s sustained on a
# 16 vCPU box with Postgres + Redis on the same network.
# [storage.write_batcher]
# channel_depth = 10000
# max_batch_size = 256
# max_batch_age_ms = 50

# Default sample uses OpenAI. For local benchmarking, set base_url to the
# provider stub: base_url = "http://127.0.0.1:18081".
#
# All api_key fields accept secret references:
#   plain:<value>  (default if no scheme prefix)
#   env:<NAME>     read from environment variable
#   file:<path>    read trimmed file contents (HashiCorp Vault / SSM workflow)
[providers.openai]
api_key = "REPLACE_WITH_REAL_OR_STUB_KEY"
base_url = "https://api.openai.com"
timeout_seconds = 120

# Optional: pick a default provider when no route matches. If omitted,
# Marg uses the first configured provider in this file.
# [providers]
# default = "openai"

# Anthropic (Claude). Enable by uncommenting and dropping in your key.
# [providers.anthropic]
# api_key = "REPLACE_WITH_ANTHROPIC_KEY"
# base_url = "https://api.anthropic.com"
# api_version = "2023-06-01"
# default_max_tokens = 1024
# timeout_seconds = 120

# Google Gemini.
# [providers.google]
# api_key = "REPLACE_WITH_GOOGLE_KEY"
# base_url = "https://generativelanguage.googleapis.com"
# api_version = "v1beta"
# timeout_seconds = 120

# AWS Bedrock. Credentials read from config or AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY env vars. session_token optional for temporary
# credentials.
# [providers.bedrock]
# region = "us-east-1"
# access_key_id = ""
# secret_access_key = ""
# session_token = ""
# default_max_tokens = 1024
# anthropic_version = "bedrock-2023-05-31"
# timeout_seconds = 120

[security]
# Marg never logs prompt or response bodies by default. Flip these only for
# debugging in a private environment.
log_prompts = false
log_responses = false

[admin]
# Admin HTTP API surface. Mounted on its own port so operators can firewall
# it separately from the proxy port. Every admin endpoint requires
# `Authorization: Bearer <admin-token>`.
enabled = true
bind = "127.0.0.1:8081"
# On first boot, Marg mints a bootstrap admin token and writes it here with
# mode 0600. Idempotent: if any active admin tokens exist already, nothing
# is minted and nothing is written. Empty string disables the bootstrap
# step entirely (operators must run `marg admin bootstrap` explicitly).
bootstrap_token_path = "./marg-admin.token"

[admin.cors]
# CORS for the admin port. Off by default. Turn on (and list origins) when
# serving the Marg Console UI from a different origin (for example, the
# Vite dev server at http://localhost:5173). When the console is served
# same-origin from this binary (the default), CORS is not needed.
enabled = false
allowed_origins = []

# The Marg Console UI ships embedded in this binary. Visit the admin port
# in a browser to land on it (root and /console both redirect to
# /console/). Auth is the same admin Bearer token as the JSON API.

[cors]
# Off by default. Operators serving the console UI from a different origin
# enable and list the origins explicitly.
enabled = false
allowed_origins = []

[rate_limits]
# Default requests-per-minute applied when a key has rpm = 0. The full keyed
# rate-limit enforcement path lives behind Redis in P03; P01 stores rpm on
# the key for forward compatibility.
default_rpm = 0
# strict_mode = false makes the token-bucket capacity equal rpm: a fresh key
# can burst up to rpm immediately and then sustains exactly rpm per rolling
# 60 s (standard token-bucket convention).
# strict_mode = true forces capacity = 1 and refill = rpm/60 per second: zero
# burst tolerance, sustained rate exactly rpm. Used by deployments that need
# every request spaced evenly.
strict_mode = false

# Pricing table overrides. Marg ships defaults for common OpenAI, Anthropic,
# Google, and Bedrock models. Override per model here. Costs are USD per
# 1K tokens.
# [[pricing]]
# model = "gpt-4o"
# input_per_1k_usd = 0.0025
# output_per_1k_usd = 0.01

# Routing rules. Each [[routes]] block is evaluated top-to-bottom. The first
# block whose `match` conditions are satisfied wins. Within a block:
#   - `primary` is the first provider tried. Format is "provider" or
#     "provider:model_override" (use the override when the upstream model
#     name differs from what the client sent).
#   - `fallback` is an ordered list. On a retriable failure (5xx, timeout,
#     network), Marg tries each fallback once. No retry storms.
#   - `split` is mutually exclusive with `primary`. Weighted distribution
#     across providers, ideal for A/B comparisons.
# If no route matches, Marg uses the default provider (see
# [providers].default).
#
# [[routes]]
# match.model = "gpt-4*"
# primary = "openai"
# fallback = ["anthropic:claude-3-5-sonnet"]
#
# [[routes]]
# match.model = "claude-*"
# primary = "anthropic"
#
# [[routes]]
# match.team = "experimental"
# split = [
#   { provider = "openai", weight = 50 },
#   { provider = "anthropic", weight = 50, model = "claude-3-5-sonnet" },
# ]

# ============================================================================
# Kavach (P09). Marg v1.0 always boots with Kavach embedded; there is no
# Cargo feature flag (ADR-011). Choose mode at runtime. First boot defaults
# to observe so operators tune policy before flipping to enforce (ADR-003).
# ============================================================================

[kavach]
# "observe" logs every gate verdict but never blocks the request.
# "enforce" applies default-deny: refused requests return 403.
mode = "observe"
# Production-grade default: a separate file (DevOps owns marg.toml,
# Security / Compliance owns policy.toml). Three accepted shapes:
#   policy_path = "/etc/marg/policy.toml"        single file
#   policy_path = "/etc/marg/policies/"          directory of *.toml files
#   policy_path = unset                          inline `[[policy]]` /
#                                                `[[invariant]]` blocks at
#                                                the top of THIS marg.toml
# See ADR-014.
# policy_path = "/etc/marg/policy.toml"

# Where the signing keypair lives. Auto-generated mode 0640 on first boot.
# Back this file up: losing it makes the audit chain unverifiable.
keypair_path = "./marg.key"

# Where the periodic audit-chain export lands. One JSONL file per process
# lifetime (cross-restart chain merging is a v1.1 concern, see
# docs/cluster-deployment.md). The directory is auto-created.
audit_export_path = "./audit/"

# How often the in-memory chain is flushed to disk. Default 60s keeps the
# crash-loss bound at one minute of traffic.
audit_flush_seconds = 60

# true (default) signs every entry with ML-DSA-65 + Ed25519 hybrid.
# false signs ML-DSA-65 only (smaller signatures, slightly faster).
audit_hybrid = true

# false (default) keeps prompt text out of the signed chain. true bundles
# the raw request body into context_snapshot for forensic replay; only
# enable in environments where the chain itself is a privileged surface.
include_prompts = false

# Surface the signed PermitToken to the caller in `X-Kavach-Permit` so
# downstream tools can verify it. Default off.
expose_permit_to_caller = false

# Forward the same `X-Kavach-Permit` header to the upstream provider call.
# Most providers ignore it; turn on only when the upstream verifier exists.
forward_permit_to_provider = false

# How long a permit token is valid before execute() refuses to honor it.
# Kavach default is 30s. Raise for slow upstream regions / cold-start LLMs.
permit_ttl_seconds = 30

# Permit signer hybrid mode. None (default) inherits `audit_hybrid` so the
# permit signer and audit chain stay in lockstep. Set explicitly when an
# operator wants e.g. hybrid audit but pq-only permits to keep the
# `x-kavach-permit` header smaller.
# permit_signer_hybrid = true

[kavach.drift]
# Marg ships with Kavach's four built-in drift detectors. Each detector is
# inert until its config knob is set, so a fully-default marg.toml has no
# drift triggers, matching the "observe first, drift later" rollout.
#
# Geo drift: tolerant mode. IP change within `km` is a warning, beyond is a
# violation. Requires the load balancer to attach `x-forwarded-geo` on
# ingress, see docs/kavach.md for the header shape. Omit to disable.
# geo_max_distance_km = 200
#
# Session-age drift: session older than this triggers a violation; a
# warning fires at 75% of the cap. Accepts "Ns" / "Nm" / "Nh" / "Nd" or a
# bare seconds integer.
# session_age_max = "24h"
#
# Device-fingerprint drift: requires the load balancer (or upstream auth
# proxy) to attach `x-marg-device-fingerprint` on ingress. When enabled,
# Marg compares the current fingerprint hash against the value persisted
# on the session row at first-sighting.
# device_fingerprint_enabled = false
#
# Behavior drift: actions-per-minute thresholds. Setting only one of the
# two enables the detector; if `_warn` is omitted Marg picks half of
# `_violation`. The pair `(warn, violation)` must be strictly increasing.
# behavior_rate_warn = 100
# behavior_rate_violation = 500

# ----------------------------------------------------------------------------
# Inline policy / invariants for dev only. PRODUCTION should set
# [kavach].policy_path above and keep this section empty. If policy_path is
# set AND inline blocks are present, the inline blocks are dropped at boot
# with a warn log.
#
# Schema is Kavach's own (kavach-core 0.1.0, see crate docs). Common
# conditions:
#   identity_role = "engineer"
#   identity_kind = "agent"
#   action = "marg.chat.gpt-4o"
#   param_max = { field = "max_tokens", max = 4000 }
#   param_in  = { field = "team", values = ["billing", "support"] }
#   time_window = "09:00-19:00 Asia/Kolkata"
#   rate_limit = { max = 60, window = "1m" }
#
# [[policy]]
# name = "engineers_can_use_gpt4"
# effect = "permit"
# conditions = [
#     { identity_role = "engineer" },
#     { action = "marg.chat.gpt-4*" },
#     { param_max = { field = "max_tokens", max = 4000 } },
# ]
#
# Invariants are hard limits Kavach enforces ahead of any policy. The Marg
# `kind` field maps to the Kavach Invariant::* builder:
#
# [[invariant]]
# kind = "param_max"
# name = "no_huge_single_request"
# field = "max_tokens"
# max = 32000
#
# [[invariant]]
# kind = "max_actions_per_session"
# name = "no_runaway_agent"
# max = 200
